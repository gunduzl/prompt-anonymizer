.git/objects/pack/*.pack

# Large binary files from dependencies
**/next-swc.*.node
**/*.so
**/*.dylib
**/*.dll

# PNPM store large files
**/.pnpm-store/**

# Package lock files (optional, but requested to exclude large files)
# pnpm-lock.yaml
# package-lock.json
# yarn.lock

# Any file larger than 10MB (conservative)
*.pack
*.zip
*.tar.gz
